{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "extractum://prompt-packs/schemas/v1/core/result.schema.json",
  "title": "Prompt Pack Canonical Result",
  "type": "object",
  "$comment": "Semantic local-shape schema for the canonical prompt-pack result envelope and core graph object shells. Cross-object graph rules, pack-specific pack_data schemas, source type_data schemas, and fragment locator schemas remain validator/pipeline checks or companion schema checks.",
  "x-prompt-pack-schema-status": "semantic",
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "result_id": {
      "$ref": "#/$defs/id_with_numeric_suffix"
    },
    "parent_result_ids": {
      "$ref": "#/$defs/nullable_ref_array"
    },
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "pack_id": {
      "type": "string",
      "minLength": 1
    },
    "pack_version": {
      "type": "string",
      "minLength": 1
    },
    "stage": {
      "type": "string",
      "minLength": 1
    },
    "created_at": {
      "type": "string",
      "format": "date-time"
    },
    "output_language": {
      "type": "string",
      "minLength": 1
    },
    "metadata": {
      "$ref": "#/$defs/metadata"
    },
    "run_context": {
      "$ref": "#/$defs/run_context"
    },
    "outputs": {
      "$ref": "#/$defs/outputs"
    },
    "source_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/source_ref"
      }
    },
    "claims": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim"
      }
    },
    "evidence": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/evidence"
      }
    },
    "claim_relations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/claim_relation"
      }
    },
    "unknowns": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/unknown"
      }
    },
    "verification_tasks": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/verification_task"
      }
    },
    "warnings": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/warning"
      }
    },
    "limitations": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/limitation"
      }
    },
    "quality_flags": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/quality_flag"
      }
    },
    "audit_refs": {
      "type": "array",
      "items": {
        "$ref": "#/$defs/audit_ref"
      }
    }
  },
  "required": [
    "schema_version",
    "result_id",
    "parent_result_ids",
    "run_id",
    "pack_id",
    "pack_version",
    "stage",
    "created_at",
    "output_language",
    "metadata",
    "run_context",
    "outputs",
    "source_refs",
    "claims",
    "evidence",
    "claim_relations",
    "unknowns",
    "verification_tasks",
    "warnings",
    "limitations",
    "quality_flags",
    "audit_refs"
  ],
  "additionalProperties": false,
  "$defs": {
    "id_with_numeric_suffix": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*_[0-9]+$"
    },
    "optional_ref_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "nullable_ref_array": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/optional_ref_array"
        }
      ]
    },
    "string_or_null": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "metadata": {
      "type": "object",
      "properties": {
        "result_type": {
          "$ref": "#/$defs/string_or_null"
        },
        "result_status": {
          "enum": [
            "complete",
            "partial",
            "error"
          ]
        },
        "producer_type": {
          "enum": [
            "llm",
            "pipeline",
            "human",
            "mixed"
          ]
        },
        "contains_partial_results": {
          "type": "boolean"
        },
        "contains_unverified_claims": {
          "type": "boolean"
        }
      },
      "required": [
        "result_status",
        "producer_type",
        "contains_partial_results",
        "contains_unverified_claims"
      ],
      "additionalProperties": false
    },
    "run_context": {
      "type": "object",
      "properties": {
        "project_id": {
          "$ref": "#/$defs/string_or_null"
        },
        "preflight_id": {
          "$ref": "#/$defs/string_or_null"
        },
        "project_goal": {
          "$ref": "#/$defs/string_or_null"
        },
        "run_goal": {
          "$ref": "#/$defs/string_or_null"
        },
        "selected_pack": {
          "type": "object",
          "properties": {
            "pack_id": {
              "type": "string",
              "minLength": 1
            },
            "pack_version": {
              "type": "string",
              "minLength": 1
            }
          },
          "required": [
            "pack_id",
            "pack_version"
          ],
          "additionalProperties": false
        },
        "control_preset": {
          "type": "string",
          "minLength": 1
        },
        "evidence_mode": {
          "type": "string",
          "minLength": 1
        },
        "output_language": {
          "type": "string",
          "minLength": 1
        },
        "source_languages": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "period": {
          "$ref": "#/$defs/period"
        },
        "input_corpus": {
          "type": "object",
          "additionalProperties": true
        },
        "model_selection": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "stage": {
                "type": "string",
                "minLength": 1
              },
              "provider": {
                "type": "string",
                "minLength": 1
              },
              "model": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "stage",
              "provider",
              "model"
            ],
            "additionalProperties": true
          }
        }
      },
      "required": [
        "selected_pack",
        "control_preset",
        "evidence_mode",
        "output_language",
        "source_languages",
        "input_corpus"
      ],
      "additionalProperties": true
    },
    "period": {
      "type": "object",
      "properties": {
        "from": {
          "$ref": "#/$defs/string_or_null"
        },
        "to": {
          "$ref": "#/$defs/string_or_null"
        }
      },
      "required": [
        "from",
        "to"
      ],
      "additionalProperties": false
    },
    "outputs": {
      "type": "object",
      "properties": {
        "summary": {
          "$ref": "#/$defs/summary"
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section"
          }
        },
        "pack_data": {
          "$ref": "#/$defs/pack_data"
        }
      },
      "required": [
        "summary",
        "sections"
      ],
      "additionalProperties": false
    },
    "summary": {
      "type": "object",
      "properties": {
        "title": {
          "$ref": "#/$defs/string_or_null"
        },
        "summary_text": {
          "type": "string",
          "minLength": 1
        },
        "claim_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "source_refs": {
          "$ref": "#/$defs/optional_ref_array"
        }
      },
      "required": [
        "summary_text",
        "claim_refs",
        "evidence_refs",
        "source_refs"
      ],
      "additionalProperties": false
    },
    "section": {
      "type": "object",
      "properties": {
        "section_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "section_type": {
          "$ref": "#/$defs/section_type"
        },
        "custom_section_type": {
          "$ref": "#/$defs/string_or_null"
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section_item"
          }
        }
      },
      "required": [
        "section_id",
        "title",
        "section_type",
        "custom_section_type",
        "items"
      ],
      "additionalProperties": false
    },
    "section_item": {
      "type": "object",
      "properties": {
        "item_id": {
          "type": "string",
          "minLength": 1
        },
        "title": {
          "$ref": "#/$defs/string_or_null"
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "claim_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "source_refs": {
          "$ref": "#/$defs/optional_ref_array"
        }
      },
      "required": [
        "item_id",
        "text",
        "claim_refs",
        "evidence_refs",
        "source_refs"
      ],
      "additionalProperties": false
    },
    "pack_data": {
      "type": "object",
      "additionalProperties": {
