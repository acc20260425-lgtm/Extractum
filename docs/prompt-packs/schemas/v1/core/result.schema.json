      "required": [
        "evidence_id",
        "claim_id",
        "source_ref_id",
        "evidence_type",
        "custom_evidence_type",
        "evidence_role",
        "custom_evidence_role",
        "fragment_type",
        "custom_fragment_type",
        "locator_data",
        "text_mode",
        "fragment_text",
        "confidence",
        "provenance"
      ],
      "additionalProperties": false
