          ],
          "minLength": 1
        },
        "internal_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_title": {
          "$ref": "#/$defs/string_or_null"
        },
        "published_at": {
          "$ref": "#/$defs/string_or_null"
        },
        "accessed_at": {
          "$ref": "#/$defs/string_or_null"
        },
        "access_status": {
          "enum": [
            "live",
            "cached",
            "unavailable",
            "custom"
          ]
        },
        "type_data": {
          "$ref": "#/$defs/schema_versioned_object"
        }
      },
      "required": [
        "source_ref_id",
        "source_type",
        "custom_source_type",
        "canonical_url",
        "internal_uri",
        "access_status",
        "type_data"
      ],
      "additionalProperties": false
    },
    "claim": {
      "type": "object",
