          "$ref": "#/$defs/claim_type"
        },
        "custom_claim_type": {
          "$ref": "#/$defs/string_or_null"
        },
        "claim_status": {
          "$ref": "#/$defs/claim_status"
        },
        "custom_claim_status": {
          "$ref": "#/$defs/string_or_null"
        },
        "claim_text": {
          "type": "string",
          "minLength": 1
        },
        "normalized_claim_text": {
          "$ref": "#/$defs/string_or_null"
        },
        "normalized_claim_language": {
          "$ref": "#/$defs/string_or_null"
        },
        "scope": {
          "$ref": "#/$defs/scope"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "evidence_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "source_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "relation_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "provenance": {
          "$ref": "#/$defs/provenance"
        }
      },
      "required": [
        "claim_id",
        "claim_type",
        "custom_claim_type",
        "claim_status",
        "custom_claim_status",
        "claim_text",
        "confidence",
        "evidence_refs",
        "source_refs",
        "relation_refs",
        "provenance"
      ],
      "additionalProperties": false
    },
    "scope": {
      "type": "object",
      "properties": {
        "period": {
