            "human_review",
            "system_event",
            "custom"
          ]
        },
        "custom_event_type": {
          "$ref": "#/$defs/string_or_null"
        },
        "stage": {
          "type": "string",
          "minLength": 1
        },
        "timestamp": {
          "type": "string",
          "format": "date-time"
        },
        "summary": {
          "$ref": "#/$defs/string_or_null"
        },
        "object_refs": {
          "$ref": "#/$defs/object_refs"
        }
      },
      "required": [
        "audit_id",
        "event_type",
        "stage",
        "timestamp"
      ],
      "additionalProperties": false
    },
    "object_refs": {
      "type": "object",
      "properties": {
        "claim_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "relation_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "source_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "unknown_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "verification_task_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "warning_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "limitation_refs": {
          "$ref": "#/$defs/optional_ref_array"
        }
      },
      "additionalProperties": false
    },
    "provenance": {
      "type": "object",
      "properties": {
        "stage": {
          "type": "string",
          "minLength": 1
        },
        "provider": {
          "type": "string",
          "minLength": 1
        },
        "model": {
          "type": "string",
          "minLength": 1
        },
        "audit_refs": {
          "$ref": "#/$defs/optional_ref_array"
        }
      },
      "required": [
        "stage",
        "provider",
        "model",
        "audit_refs"
      ],
      "additionalProperties": false
    },
    "schema_versioned_object": {
      "type": "object",
      "properties": {
        "schema_version": {
          "const": "1.0"
        }
      },
      "required": [
        "schema_version"
      ],
      "additionalProperties": true
    },
    "locator_data_or_null": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "$ref": "#/$defs/schema_versioned_object"
        }
      ]
    },
    "confidence": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "basis": {
              "enum": [
                "multiple_corroborating_sources",
                "single_source",
                "strong_direct_evidence",
                "weak_or_indirect_evidence",
                "conflicting_sources",
                "inference_chain",
                "expert_consensus",
                "llm_prior_only",
                "no_evidence",
                "custom"
              ]
            },
            "custom_basis": {
              "$ref": "#/$defs/string_or_null"
            },
            "method": {
              "enum": [
                "llm_assessment",
                "rule_based",
                "human_review",
                "aggregated",
                "inherited",
                "custom"
              ]
            },
            "custom_method": {
              "$ref": "#/$defs/string_or_null"
            }
          },
          "required": [
            "score",
            "basis",
            "custom_basis",
            "method",
            "custom_method"
          ],
          "additionalProperties": false
        }
      ]
    },
    "section_type": {
      "enum": [
        "summary",
        "trends",
        "assessment",
        "risks",
        "recommendations",
        "custom"
      ]
    },
    "source_type": {
      "enum": [
        "youtube_video",
        "web_page",
        "rss_entry",
        "telegram_post",
        "telegram_channel_snapshot",
        "telegram_chat_snapshot",
        "forum_thread",
        "custom"
      ]
    },
    "claim_type": {
      "enum": [
        "factual",
        "evaluative",
        "predictive",
        "causal",
        "normative",
        "hypothesis",
        "custom"
      ]
    },
    "claim_status": {
      "enum": [
        "extracted",
        "inferred",
        "verified",
        "partially_verified",
        "unverified",
        "retracted",
        "custom"
      ]
    },
    "evidence_type": {
      "enum": [
        "fragment",
        "inference",
        "custom"
      ]
    },
    "evidence_role": {
      "enum": [
        "supports",
        "contradicts",
        "qualifies",
        "contextualizes",
        "custom"
      ]
    },
    "fragment_type_or_null": {
      "enum": [
        "text_range",
        "paragraph",
        "video_timestamp_range",
        "audio_timestamp_range",
        "post",
        "comment",
        "thread_reply",
        "image_region",
        "document_section",
        "aggregate",
        "custom",
        null
      ]
    },
    "text_mode_or_null": {
      "enum": [
        "verbatim",
        "paraphrase",
        "summary",
        "description",
        null
      ]
    },
    "relation_type": {
      "enum": [
        "contradicts",
        "supports",
        "qualifies",
        "supersedes",
        "custom"
      ]
    },
    "unknown_type": {
      "enum": [
        "missing_data",
        "unresolvable",
        "conflicting",
        "out_of_scope",
        "requires_expertise",
        "custom"
      ]
    },
    "task_type": {
      "enum": [
        "manual_check",
        "source_search",
        "expert_review",
        "re_run_with_data",
        "cross_reference",
        "custom"
      ]
    },
    "priority": {
      "enum": [
        "high",
        "medium",
        "low",
        null
      ]
    },
    "severity": {
      "enum": [
        "high",
        "medium",
        "low",
        null
      ]
    },
    "warning_type": {
      "enum": [
        "single_source_claim",
        "low_confidence_output",
        "unresolved_contradiction",
        "missing_evidence",
        "conflicting_sources",
        "temporal_gap",
        "access_unavailable",
        "custom"
      ]
    },
    "limitation_type": {
      "enum": [
        "corpus_coverage_limited",
        "temporal_scope_narrow",
        "language_bias",
        "methodology_constraint",
        "out_of_scope_topic",
        "data_freshness",
        "custom"
      ]
    },
    "quality_flag_type": {
      "enum": [
        "insufficient_data",
        "processing_failed",
        "single_source_claim",
        "low_confidence_result",
        "unverified_claims_present",
        "corpus_coverage_limited",
        "conflicting_sources_unresolved",
        "out_of_scope_content_present",
        "partial_result",
