{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "extractum://prompt-packs/schemas/v1/stage-io/final_synthesis.schema.json",
  "title": "Stage I/O: final_synthesis",
  "type": "object",
  "$comment": "Semantic local-shape schema for final_synthesis input and LLM output payloads. The stage drafts readable outputs over the fixed canonical graph and pack data; pipeline code assigns section/item IDs and assembles metadata, warnings, limitations, quality flags, and audit refs.",
  "x-prompt-pack-schema-status": "semantic",
  "oneOf": [
    {
      "$ref": "#/$defs/input_payload"
    },
    {
      "$ref": "#/$defs/llm_output"
    }
  ],
  "$defs": {
    "ref_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "optional_ref_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "id_with_numeric_suffix": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*_[0-9]+$"
    },
    "claim_type": {
      "enum": [
        "factual",
        "evaluative",
        "predictive",
        "causal",
        "normative",
        "hypothesis",
        "custom"
      ]
    },
    "claim_status": {
      "enum": [
        "extracted",
        "inferred",
        "verified",
        "partially_verified",
        "unverified",
        "retracted",
        "custom"
      ]
    },
    "evidence_type": {
      "enum": [
        "fragment",
        "inference",
        "custom"
      ]
    },
    "evidence_role": {
      "enum": [
        "supports",
        "contradicts",
        "qualifies",
        "contextualizes",
        "custom"
      ]
    },
    "source_type": {
      "enum": [
        "youtube_video",
        "web_page",
        "rss_entry",
        "telegram_post",
        "telegram_channel_snapshot",
        "telegram_chat_snapshot",
        "forum_thread",
        "custom"
      ]
    },
    "section_type": {
      "enum": [
        "summary",
        "trends",
        "assessment",
        "risks",
        "recommendations",
        "custom"
      ]
    },
    "input_payload": {
      "type": "object",
      "properties": {
        "stage_io_version": {
          "const": "1.0"
        },
        "schema_version": {
          "const": "1.0"
        },
        "stage": {
          "const": "final_synthesis"
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_version": {
          "type": "string",
          "minLength": 1
        },
        "input_result_ids": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "audit_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "allowed_claim_ids": {
          "$ref": "#/$defs/ref_array"
        },
        "allowed_evidence_ids": {
          "$ref": "#/$defs/ref_array"
        },
        "allowed_source_ref_ids": {
          "$ref": "#/$defs/ref_array"
        },
        "claims": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/claim_registry_entry"
          }
        },
        "evidence": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_registry_entry"
          }
        },
        "source_refs": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_registry_entry"
          }
        },
        "claim_relations": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/relation_registry_entry"
          }
        },
        "pack_data": {
          "$ref": "#/$defs/pack_data"
        },
        "registry_refs": {
          "$ref": "#/$defs/registry_refs"
        }
      },
      "required": [
        "stage_io_version",
        "schema_version",
        "stage",
        "run_id",
        "pack_id",
        "pack_version",
        "allowed_claim_ids",
        "allowed_evidence_ids",
        "allowed_source_ref_ids",
        "claims",
        "pack_data"
      ],
      "additionalProperties": false
    },
    "llm_output": {
      "type": "object",
      "properties": {
        "outputs_candidate": {
          "$ref": "#/$defs/outputs_candidate"
        }
      },
      "required": [
        "outputs_candidate"
      ],
      "additionalProperties": false
    },
    "outputs_candidate": {
      "type": "object",
      "properties": {
        "summary": {
          "$ref": "#/$defs/summary_candidate"
        },
        "sections": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section_candidate"
          }
        }
      },
      "required": [
        "summary",
        "sections"
      ],
      "additionalProperties": false
    },
    "summary_candidate": {
      "type": "object",
      "properties": {
        "title": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "summary_text": {
          "type": "string",
          "minLength": 1
        },
        "claim_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "source_refs": {
          "$ref": "#/$defs/optional_ref_array"
        }
      },
      "required": [
        "summary_text",
        "claim_refs",
        "evidence_refs",
        "source_refs"
      ],
      "additionalProperties": false
    },
    "section_candidate": {
      "type": "object",
      "properties": {
        "section_type": {
          "$ref": "#/$defs/section_type"
        },
        "custom_section_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "items": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/section_item_candidate"
          }
        }
      },
      "required": [
        "section_type",
        "custom_section_type",
        "title",
        "items"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "section_type": {
                "const": "custom"
              }
            },
            "required": [
              "section_type"
            ]
          },
          "then": {
            "properties": {
              "custom_section_type": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "custom_section_type"
            ]
          },
          "else": {
            "properties": {
              "custom_section_type": {
                "type": "null"
              }
            }
          }
        }
      ]
    },
    "section_item_candidate": {
      "type": "object",
      "properties": {
        "title": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "text": {
          "type": "string",
          "minLength": 1
        },
        "claim_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "source_refs": {
          "$ref": "#/$defs/optional_ref_array"
        }
      },
      "required": [
        "text",
        "claim_refs",
        "evidence_refs",
        "source_refs"
      ],
      "additionalProperties": false
    },
    "claim_registry_entry": {
      "type": "object",
      "properties": {
        "claim_id": {
          "$ref": "#/$defs/id_with_numeric_suffix"
        },
        "claim_text": {
          "type": "string",
          "minLength": 1
        },
        "claim_type": {
          "$ref": "#/$defs/claim_type"
        },
        "claim_status": {
          "$ref": "#/$defs/claim_status"
        },
        "evidence_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "source_refs": {
          "$ref": "#/$defs/optional_ref_array"
        }
      },
      "required": [
        "claim_id",
        "claim_text"
      ],
      "additionalProperties": false
    },
    "evidence_registry_entry": {
      "type": "object",
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/id_with_numeric_suffix"
        },
        "claim_id": {
          "$ref": "#/$defs/id_with_numeric_suffix"
        },
        "source_ref_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "evidence_type": {
          "$ref": "#/$defs/evidence_type"
        },
        "evidence_role": {
          "$ref": "#/$defs/evidence_role"
        },
        "fragment_text": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "context_text": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "required": [
        "evidence_id",
        "claim_id"
      ],
      "additionalProperties": false
    },
    "source_registry_entry": {
      "type": "object",
      "properties": {
        "source_ref_id": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "$ref": "#/$defs/source_type"
        },
        "custom_source_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_title": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "canonical_url": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "internal_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "required": [
        "source_ref_id",
        "source_type"
      ],
      "additionalProperties": false
    },
    "relation_registry_entry": {
      "type": "object",
      "properties": {
        "relation_id": {
          "$ref": "#/$defs/id_with_numeric_suffix"
        },
        "relation_type": {
          "enum": [
            "contradicts",
            "supports",
            "qualifies",
            "supersedes",
            "custom"
          ]
        },
        "source_claim_id": {
          "$ref": "#/$defs/id_with_numeric_suffix"
        },
        "target_claim_id": {
          "$ref": "#/$defs/id_with_numeric_suffix"
        },
        "description": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "evidence_refs": {
          "$ref": "#/$defs/optional_ref_array"
        }
      },
      "required": [
        "relation_id",
        "relation_type",
        "source_claim_id",
        "target_claim_id"
      ],
      "additionalProperties": false
    },
    "pack_data": {
      "type": "object",
      "minProperties": 1,
      "additionalProperties": {
        "type": "object"
      }
    },
    "registry_refs": {
      "type": "object",
      "properties": {
        "claim_registry_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "evidence_registry_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_registry_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "pack_data_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "required": [
        "claim_registry_uri",
        "evidence_registry_uri",
        "source_registry_uri",
        "pack_data_uri"
      ],
      "additionalProperties": false
    }
  }
}
