{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "extractum://prompt-packs/schemas/v1/stage-io/claim_extraction.schema.json",
  "title": "Stage I/O: claim_extraction",
  "type": "object",
  "$comment": "Semantic local-shape schema for claim_extraction input and LLM output payloads. The stage creates claim candidates over pre-contract fragment candidates; canonical claim_id and evidence_id values are assigned later by pipeline code.",
  "x-prompt-pack-schema-status": "semantic",
  "oneOf": [
    {
      "$ref": "#/$defs/input_payload"
    },
    {
      "$ref": "#/$defs/output_payload"
    },
    {
      "$ref": "#/$defs/llm_output"
    }
  ],
  "$defs": {
    "ref_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "optional_ref_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "fragment_type": {
      "enum": [
        "text_range",
        "paragraph",
        "video_timestamp_range",
        "audio_timestamp_range",
        "post",
        "comment",
        "thread_reply",
        "image_region",
        "document_section",
        "aggregate",
        "custom"
      ]
    },
    "claim_type": {
      "enum": [
        "factual",
        "evaluative",
        "predictive",
        "causal",
        "normative",
        "hypothesis",
        "custom"
      ]
    },
    "claim_status": {
      "enum": [
        "extracted",
        "inferred",
        "verified",
        "partially_verified",
        "unverified",
        "retracted",
        "custom"
      ]
    },
    "unknown_type": {
      "enum": [
        "missing_data",
        "unresolvable",
        "conflicting",
        "out_of_scope",
        "requires_expertise",
        "custom"
      ]
    },
    "task_type": {
      "enum": [
        "manual_check",
        "source_search",
        "expert_review",
        "re_run_with_data",
        "cross_reference",
        "custom"
      ]
    },
    "warning_type": {
      "enum": [
        "single_source_claim",
        "low_confidence_output",
        "unresolved_contradiction",
        "missing_evidence",
        "conflicting_sources",
        "temporal_gap",
        "access_unavailable",
        "custom"
      ]
    },
    "severity": {
      "enum": [
        "high",
        "medium",
        "low",
        null
      ]
    },
    "common_envelope": {
      "type": "object",
      "properties": {
        "stage_io_version": {
          "const": "1.0"
        },
        "schema_version": {
          "const": "1.0"
        },
        "stage": {
          "const": "claim_extraction"
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_version": {
          "type": "string",
          "minLength": 1
        },
        "input_result_ids": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "audit_refs": {
          "$ref": "#/$defs/optional_ref_array"
        }
      },
      "required": [
        "stage_io_version",
        "schema_version",
        "stage",
        "run_id",
        "pack_id",
        "pack_version"
      ],
      "additionalProperties": false
    },
    "input_payload": {
      "type": "object",
      "properties": {
        "stage_io_version": {
          "const": "1.0"
        },
        "schema_version": {
          "const": "1.0"
        },
        "stage": {
          "const": "claim_extraction"
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_version": {
          "type": "string",
          "minLength": 1
        },
        "input_result_ids": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "audit_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "allowed_fragment_candidate_ids": {
          "$ref": "#/$defs/ref_array"
        },
        "allowed_source_ref_ids": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "source_registry": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_registry_entry"
          }
        },
        "fragment_registry": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/fragment_registry_entry"
          }
        },
        "registry_refs": {
          "$ref": "#/$defs/registry_refs"
        },
        "task": {
          "$ref": "#/$defs/task_instruction"
        }
      },
      "required": [
        "stage_io_version",
        "schema_version",
        "stage",
        "run_id",
        "pack_id",
        "pack_version",
        "allowed_fragment_candidate_ids",
        "fragment_registry"
      ],
      "additionalProperties": false
    },
    "source_registry_entry": {
      "type": "object",
      "properties": {
        "source_ref_id": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "type": "string",
          "minLength": 1
        },
        "canonical_url": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_title": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "required": [
        "source_ref_id",
        "source_type"
      ],
      "additionalProperties": true
    },
    "task_instruction": {
      "type": "object",
      "properties": {
        "instruction": {
          "type": "string",
          "minLength": 1
        },
        "output_contract": {
          "type": "string",
          "minLength": 1
        }
      },
      "required": [
        "instruction",
        "output_contract"
      ],
      "additionalProperties": true
    },
    "llm_output": {
      "type": "object",
      "properties": {
        "claim_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/claim_candidate"
          }
        },
        "unknown_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/unknown_candidate"
          }
        },
        "verification_task_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verification_task_candidate"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning_candidate"
          }
        }
      },
      "required": [
        "claim_candidates",
        "unknown_candidates",
        "verification_task_candidates"
      ],
      "additionalProperties": false
    },
    "output_payload": {
      "type": "object",
      "properties": {
        "stage_io_version": {
          "const": "1.0"
        },
        "schema_version": {
          "const": "1.0"
        },
        "stage": {
          "const": "claim_extraction"
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_version": {
          "type": "string",
          "minLength": 1
        },
        "input_result_ids": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "audit_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "claim_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/claim_candidate"
          }
        },
        "unknown_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/unknown_candidate"
          }
        },
        "verification_task_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/verification_task_candidate"
          }
        },
        "warnings": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning_candidate"
          }
        }
      },
      "required": [
        "stage_io_version",
        "schema_version",
        "stage",
        "run_id",
        "pack_id",
        "pack_version",
        "claim_candidates",
        "unknown_candidates",
        "verification_task_candidates"
      ],
      "additionalProperties": false
    },
    "fragment_registry_entry": {
      "type": "object",
      "properties": {
        "candidate_id": {
          "type": "string",
          "minLength": 1
        },
        "source_ref_id": {
          "type": "string",
          "minLength": 1
        },
        "fragment_type": {
          "$ref": "#/$defs/fragment_type"
        },
        "custom_fragment_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "locator_data": {
          "$ref": "#/$defs/locator_data_stub"
        },
        "fragment_text": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "observation_summary": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "candidate_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "salience": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "context_text": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "verbatim_quote": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "parent_candidate_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "child_candidate_ids": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "language": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "snapshot_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "created_by_stage": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "required": [
        "candidate_id",
        "source_ref_id",
        "fragment_type",
        "locator_data"
      ],
      "additionalProperties": false,
      "anyOf": [
        {
          "required": [
            "fragment_text"
          ],
          "properties": {
            "fragment_text": {
              "type": "string",
              "minLength": 1
            }
          }
        },
        {
          "required": [
            "observation_summary"
          ],
          "properties": {
            "observation_summary": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      ]
    },
    "claim_candidate": {
      "type": "object",
      "properties": {
        "temp_claim_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "claim_text": {
          "type": "string",
          "minLength": 1
        },
        "claim_type": {
          "$ref": "#/$defs/claim_type"
        },
        "custom_claim_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "claim_status": {
          "$ref": "#/$defs/claim_status"
        },
        "custom_claim_status": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "normalized_claim_text": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "normalized_claim_language": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "fragment_candidate_refs": {
          "$ref": "#/$defs/ref_array"
        },
        "source_ref_ids": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        },
        "rationale": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "required": [
        "claim_text",
        "claim_type",
        "claim_status",
        "fragment_candidate_refs",
        "confidence"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "claim_type": {
                "const": "custom"
              }
            },
            "required": [
              "claim_type"
            ]
          },
          "then": {
            "properties": {
              "custom_claim_type": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "custom_claim_type"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "claim_status": {
                "const": "custom"
              }
            },
            "required": [
              "claim_status"
            ]
          },
          "then": {
            "properties": {
              "custom_claim_status": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "custom_claim_status"
            ]
          }
        }
      ]
    },
    "unknown_candidate": {
      "type": "object",
      "properties": {
        "unknown_type": {
          "$ref": "#/$defs/unknown_type"
        },
        "custom_unknown_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "why_it_matters": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "fragment_candidate_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      },
      "required": [
        "unknown_type",
        "title",
        "description"
      ],
      "additionalProperties": false
    },
    "verification_task_candidate": {
      "type": "object",
      "properties": {
        "task_type": {
          "$ref": "#/$defs/task_type"
        },
        "custom_task_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "priority": {
          "enum": [
            "high",
            "medium",
            "low",
            null
          ]
        },
        "task": {
          "type": "string",
          "minLength": 1
        },
        "where_to_check": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "expected_evidence_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "status_change_condition": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "fragment_candidate_refs": {
          "$ref": "#/$defs/optional_ref_array"
        }
      },
      "required": [
        "task_type",
        "priority",
        "task"
      ],
      "additionalProperties": false
    },
    "warning_candidate": {
      "type": "object",
      "properties": {
        "warning_type": {
          "$ref": "#/$defs/warning_type"
        },
        "custom_warning_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "fragment_candidate_refs": {
          "$ref": "#/$defs/optional_ref_array"
        }
      },
      "required": [
        "warning_type",
        "severity",
        "message"
      ],
      "additionalProperties": false
    },
    "confidence": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "basis": {
              "enum": [
                "multiple_corroborating_sources",
                "single_source",
                "strong_direct_evidence",
                "weak_or_indirect_evidence",
                "conflicting_sources",
                "inference_chain",
                "expert_consensus",
                "llm_prior_only",
                "no_evidence",
                "custom"
              ]
            },
            "custom_basis": {
              "type": [
                "string",
                "null"
              ],
              "minLength": 1
            },
            "method": {
              "enum": [
                "llm_assessment",
                "rule_based",
                "human_review",
                "aggregated",
                "inherited",
                "custom"
              ]
            },
            "custom_method": {
              "type": [
                "string",
                "null"
              ],
              "minLength": 1
            }
          },
          "required": [
            "score",
            "basis",
            "custom_basis",
            "method",
            "custom_method"
          ],
          "additionalProperties": false
        }
      ]
    },
    "locator_data_stub": {
      "type": "object",
      "properties": {
        "schema_version": {
          "const": "1.0"
        }
      },
      "required": [
        "schema_version"
      ],
      "additionalProperties": true
    },
    "registry_refs": {
      "type": "object",
      "properties": {
        "fragment_registry_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "claim_registry_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "evidence_registry_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "required": [
        "fragment_registry_uri",
        "claim_registry_uri",
        "evidence_registry_uri"
      ],
      "additionalProperties": false
    }
  }
}
