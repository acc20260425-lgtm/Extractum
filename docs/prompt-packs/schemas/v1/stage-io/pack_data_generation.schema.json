{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "extractum://prompt-packs/schemas/v1/stage-io/pack_data_generation.schema.json",
  "title": "Stage I/O: pack_data_generation",
  "type": "object",
  "$comment": "Semantic local-shape schema for pack_data_generation input and LLM output payloads. The stage creates pack-specific projection candidates over a fixed claim/evidence/source graph; pipeline code assigns pack-specific object IDs, rebuilds derived traversal refs, and runs pack-specific schemas and validator rules after assembly.",
  "x-prompt-pack-schema-status": "semantic",
  "oneOf": [
    {
      "$ref": "#/$defs/input_payload"
    },
    {
      "$ref": "#/$defs/llm_output"
    }
  ],
  "$defs": {
    "ref_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "minItems": 1,
      "uniqueItems": true
    },
    "optional_ref_array": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      },
      "uniqueItems": true
    },
    "id_with_numeric_suffix": {
      "type": "string",
      "pattern": "^[A-Za-z][A-Za-z0-9_]*_[0-9]+$"
    },
    "claim_type": {
      "enum": [
        "factual",
        "evaluative",
        "predictive",
        "causal",
        "normative",
        "hypothesis",
        "custom"
      ]
    },
    "evidence_type": {
      "enum": [
        "fragment",
        "inference",
        "custom"
      ]
    },
    "evidence_role": {
      "enum": [
        "supports",
        "contradicts",
        "qualifies",
        "contextualizes",
        "custom"
      ]
    },
    "source_type": {
      "enum": [
        "youtube_video",
        "web_page",
        "rss_entry",
        "telegram_post",
        "telegram_channel_snapshot",
        "telegram_chat_snapshot",
        "forum_thread",
        "custom"
      ]
    },
    "unknown_type": {
      "enum": [
        "missing_data",
        "unresolvable",
        "conflicting",
        "out_of_scope",
        "requires_expertise",
        "custom"
      ]
    },
    "warning_type": {
      "enum": [
        "single_source_claim",
        "low_confidence_output",
        "unresolved_contradiction",
        "missing_evidence",
        "conflicting_sources",
        "temporal_gap",
        "access_unavailable",
        "custom"
      ]
    },
    "severity": {
      "enum": [
        "high",
        "medium",
        "low",
        null
      ]
    },
    "input_payload": {
      "type": "object",
      "properties": {
        "stage_io_version": {
          "const": "1.0"
        },
        "schema_version": {
          "const": "1.0"
        },
        "stage": {
          "const": "pack_data_generation"
        },
        "run_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_id": {
          "type": "string",
          "minLength": 1
        },
        "pack_version": {
          "type": "string",
          "minLength": 1
        },
        "input_result_ids": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "audit_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "allowed_claim_ids": {
          "$ref": "#/$defs/ref_array"
        },
        "allowed_evidence_ids": {
          "$ref": "#/$defs/ref_array"
        },
        "allowed_source_ref_ids": {
          "$ref": "#/$defs/ref_array"
        },
        "claim_registry": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/claim_registry_entry"
          }
        },
        "evidence_registry": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/evidence_registry_entry"
          }
        },
        "source_registry": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/source_registry_entry"
          }
        },
        "registry_refs": {
          "$ref": "#/$defs/registry_refs"
        }
      },
      "required": [
        "stage_io_version",
        "schema_version",
        "stage",
        "run_id",
        "pack_id",
        "pack_version",
        "allowed_claim_ids",
        "allowed_evidence_ids",
        "allowed_source_ref_ids",
        "claim_registry",
        "evidence_registry",
        "source_registry"
      ],
      "additionalProperties": false
    },
    "llm_output": {
      "type": "object",
      "properties": {
        "pack_data_candidate": {
          "$ref": "#/$defs/pack_data_candidate"
        },
        "unknown_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/unknown_candidate"
          }
        },
        "warning_candidates": {
          "type": "array",
          "items": {
            "$ref": "#/$defs/warning_candidate"
          }
        }
      },
      "required": [
        "pack_data_candidate",
        "unknown_candidates",
        "warning_candidates"
      ],
      "additionalProperties": false
    },
    "claim_registry_entry": {
      "type": "object",
      "properties": {
        "claim_id": {
          "$ref": "#/$defs/id_with_numeric_suffix"
        },
        "claim_text": {
          "type": "string",
          "minLength": 1
        },
        "claim_type": {
          "$ref": "#/$defs/claim_type"
        },
        "evidence_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "source_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      },
      "required": [
        "claim_id",
        "claim_text"
      ],
      "additionalProperties": false
    },
    "evidence_registry_entry": {
      "type": "object",
      "properties": {
        "evidence_id": {
          "$ref": "#/$defs/id_with_numeric_suffix"
        },
        "claim_id": {
          "$ref": "#/$defs/id_with_numeric_suffix"
        },
        "source_ref_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "evidence_type": {
          "$ref": "#/$defs/evidence_type"
        },
        "evidence_role": {
          "$ref": "#/$defs/evidence_role"
        },
        "fragment_text": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "context_text": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "required": [
        "evidence_id",
        "claim_id"
      ],
      "additionalProperties": false
    },
    "source_registry_entry": {
      "type": "object",
      "properties": {
        "source_ref_id": {
          "type": "string",
          "minLength": 1
        },
        "source_type": {
          "$ref": "#/$defs/source_type"
        },
        "custom_source_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_title": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "canonical_url": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "internal_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "required": [
        "source_ref_id",
        "source_type"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "source_type": {
                "const": "custom"
              }
            },
            "required": [
              "source_type"
            ]
          },
          "then": {
            "properties": {
              "custom_source_type": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "custom_source_type"
            ]
          }
        }
      ]
    },
    "pack_data_candidate": {
      "type": "object",
      "minProperties": 1,
      "maxProperties": 1,
      "propertyNames": {
        "type": "string",
        "minLength": 1
      },
      "additionalProperties": {
        "type": "object"
      }
    },
    "unknown_candidate": {
      "type": "object",
      "properties": {
        "unknown_type": {
          "$ref": "#/$defs/unknown_type"
        },
        "custom_unknown_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "title": {
          "type": "string",
          "minLength": 1
        },
        "description": {
          "type": "string",
          "minLength": 1
        },
        "why_it_matters": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "claim_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "source_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "confidence": {
          "$ref": "#/$defs/confidence"
        }
      },
      "required": [
        "unknown_type",
        "title",
        "description"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "unknown_type": {
                "const": "custom"
              }
            },
            "required": [
              "unknown_type"
            ]
          },
          "then": {
            "properties": {
              "custom_unknown_type": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "custom_unknown_type"
            ]
          }
        }
      ]
    },
    "warning_candidate": {
      "type": "object",
      "properties": {
        "warning_type": {
          "$ref": "#/$defs/warning_type"
        },
        "custom_warning_type": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "severity": {
          "$ref": "#/$defs/severity"
        },
        "message": {
          "type": "string",
          "minLength": 1
        },
        "claim_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "source_refs": {
          "$ref": "#/$defs/optional_ref_array"
        },
        "evidence_refs": {
          "$ref": "#/$defs/optional_ref_array"
        }
      },
      "required": [
        "warning_type",
        "severity",
        "message"
      ],
      "additionalProperties": false,
      "allOf": [
        {
          "if": {
            "properties": {
              "warning_type": {
                "const": "custom"
              }
            },
            "required": [
              "warning_type"
            ]
          },
          "then": {
            "properties": {
              "custom_warning_type": {
                "type": "string",
                "minLength": 1
              }
            },
            "required": [
              "custom_warning_type"
            ]
          }
        }
      ]
    },
    "confidence": {
      "anyOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "properties": {
            "score": {
              "type": "number",
              "minimum": 0,
              "maximum": 1
            },
            "basis": {
              "enum": [
                "multiple_corroborating_sources",
                "single_source",
                "strong_direct_evidence",
                "weak_or_indirect_evidence",
                "conflicting_sources",
                "inference_chain",
                "expert_consensus",
                "llm_prior_only",
                "no_evidence",
                "custom"
              ]
            },
            "custom_basis": {
              "type": [
                "string",
                "null"
              ],
              "minLength": 1
            },
            "method": {
              "enum": [
                "llm_assessment",
                "rule_based",
                "human_review",
                "aggregated",
                "inherited",
                "custom"
              ]
            },
            "custom_method": {
              "type": [
                "string",
                "null"
              ],
              "minLength": 1
            }
          },
          "required": [
            "score",
            "basis",
            "custom_basis",
            "method",
            "custom_method"
          ],
          "additionalProperties": false
        }
      ]
    },
    "registry_refs": {
      "type": "object",
      "properties": {
        "fragment_registry_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "claim_registry_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "evidence_registry_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "source_registry_uri": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        }
      },
      "required": [
        "fragment_registry_uri",
        "claim_registry_uri",
        "evidence_registry_uri",
        "source_registry_uri"
      ],
      "additionalProperties": false
    }
  }
}
