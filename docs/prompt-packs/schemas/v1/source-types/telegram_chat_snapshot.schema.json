{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "extractum://prompt-packs/schemas/v1/source-types/telegram_chat_snapshot.schema.json",
  "title": "Source Type Data: telegram_chat_snapshot",
  "type": "object",
  "$comment": "Semantic local-shape schema for source_ref.type_data where source_type = telegram_chat_snapshot. This material is a root context, so parent_context fields are null. snapshot_from and snapshot_to are filled only together. creator_type is unknown because a chat has no single author.",
  "x-prompt-pack-schema-status": "semantic",
  "properties": {
    "schema_version": {
      "const": "1.0"
    },
    "chat_platform_id": {
      "type": [
        "string",
        "null"
      ],
      "minLength": 1
    },
    "member_count": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "message_count_in_snapshot": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "unique_author_count": {
      "type": [
        "integer",
        "null"
      ],
      "minimum": 0
    },
    "snapshot_from": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "snapshot_to": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "scraped_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "creator": {
      "type": "object",
      "properties": {
        "creator_type": {
          "const": "unknown"
        },
        "custom_creator_type": {
          "type": "null"
        },
        "id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "platform_specific_id": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "display_name": {
          "type": [
            "string",
            "null"
          ],
          "minLength": 1
        },
        "profile_url": {
          "type": [
            "string",
            "null"
          ],
          "format": "uri"
        }
      },
      "required": [
        "creator_type",
        "custom_creator_type",
        "id",
        "platform_specific_id",
        "display_name",
        "profile_url"
      ],
      "additionalProperties": false
    },
    "parent_context": {
      "type": "object",
      "properties": {
        "context_type": {
          "type": "null"
        },
        "custom_context_type": {
          "type": "null"
        },
        "context_id": {
          "type": "null"
        },
        "platform_specific_id": {
          "type": "null"
        },
        "context_title": {
          "type": "null"
        },
        "context_url": {
          "type": "null"
        }
      },
      "required": [
        "context_type",
        "custom_context_type",
        "context_id",
        "platform_specific_id",
        "context_title",
        "context_url"
      ],
      "additionalProperties": false
    },
    "extra_metadata": {
      "type": "object",
      "additionalProperties": {
        "anyOf": [
          {
            "type": [
              "string",
              "number",
              "integer",
              "boolean",
              "null"
            ]
          },
          {
            "type": "array",
            "items": {
              "type": [
                "string",
                "number",
                "integer",
                "boolean",
                "null"
              ]
            }
          }
        ]
      }
    }
  },
  "required": [
    "schema_version",
    "chat_platform_id",
    "member_count",
    "message_count_in_snapshot",
    "unique_author_count",
    "snapshot_from",
    "snapshot_to",
    "scraped_at",
    "creator",
    "parent_context",
    "extra_metadata"
  ],
  "allOf": [
    {
      "if": {
        "properties": {
          "snapshot_from": {
            "type": "null"
          }
        },
        "required": [
          "snapshot_from"
        ]
      },
      "then": {
        "properties": {
          "snapshot_to": {
            "type": "null"
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "snapshot_to": {
            "type": "null"
          }
        },
        "required": [
          "snapshot_to"
        ]
      },
      "then": {
        "properties": {
          "snapshot_from": {
            "type": "null"
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
