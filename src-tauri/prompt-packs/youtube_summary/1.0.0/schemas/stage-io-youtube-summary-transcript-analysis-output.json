{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "stage-io/youtube_summary_transcript_analysis_output",
  "type": "object",
  "additionalProperties": true,
  "required": [
    "stage_io_version",
    "schema_version",
    "stage",
    "video_candidate",
    "claim_candidates",
    "evidence_fragment_candidates",
    "warning_candidates"
  ],
  "properties": {
    "stage_io_version": { "const": "1.0" },
    "schema_version": { "const": "1.0" },
    "stage": { "const": "youtube_summary/transcript_analysis" },
    "video_candidate": { "type": "object" },
    "claim_candidates": {
      "type": "array",
      "items": { "type": "object" }
    },
    "evidence_fragment_candidates": {
      "type": "array",
      "items": { "type": "object" }
    },
    "warning_candidates": {
      "type": "array",
      "items": { "type": "object" }
    }
  }
}
